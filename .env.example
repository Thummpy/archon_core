# Required: OAuth token for Anthropic API access via Claude Max subscription.
# Generate with: scripts/setup-oauth.sh
CLAUDE_CODE_OAUTH_TOKEN=

# Optional: Host port Archon binds to. Defaults to 3000 if unset.
# PORT=3000

# Optional: GitHub token for cloning private repos inside the container.
# Generate a fine-grained PAT at https://github.com/settings/tokens or use: gh auth token
# GITHUB_TOKEN=

# Optional: GCP project configuration for Terraform cloud deployment.
# See docs/TERRAFORM-SETUP.md for details.
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_REGION=us-central1
# GCP_ZONE=us-central1-a

# Required for OAuth2 authentication: Google OAuth2 credentials.
# Create at https://console.cloud.google.com/apis/credentials
# Set authorized redirect URI: https://<your-ARCHON_DOMAIN>/oauth2/callback
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=

# Required: Cookie secret for OAuth2 Proxy session encryption.
# Generate with: openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=

# Required: Email address allowed to access Archon via OAuth2.
OAUTH_EMAIL=

# Domain for HTTPS access (set automatically on GCP via sslip.io, or manually)
# Example: ARCHON_DOMAIN=34-56-78-90.sslip.io
ARCHON_DOMAIN=localhost
