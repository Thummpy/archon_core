#!/usr/bin/env bash
# =============================================================================
# Pre-Commit Hook
# =============================================================================
# Runs validation (lint, type check, unit tests, build) before every commit.
# This enforces test standards at the git level — even outside Claude Code.
#
# Bypass: SKIP_VALIDATE=1 git commit -m "wip: checkpoint"
# =============================================================================

set -euo pipefail

if [ "${SKIP_VALIDATE:-0}" = "1" ]; then
  echo "⊘ Pre-commit validation skipped (SKIP_VALIDATE=1)"
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
VALIDATE_SCRIPT="$REPO_ROOT/.claude/scripts/validate.sh"

if [ ! -x "$VALIDATE_SCRIPT" ]; then
  echo "⊘ Pre-commit validation skipped (validate.sh not found or not executable)"
  exit 0
fi

echo "Running pre-commit validation..."
EXIT_CODE=0
"$VALIDATE_SCRIPT" --skip-integration || EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "Commit blocked — validation failed. Fix the issues above or bypass with:"
  echo "  SKIP_VALIDATE=1 git commit -m \"your message\""
  exit 1
fi
